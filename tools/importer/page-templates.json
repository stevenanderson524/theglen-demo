          "blocks": [
            "columns-icons"
          ],
          "defaultContent": []
        },
        {
          "id": "section-3",
          "name": "NASCAR Intro",
          "selector": "#pg-2-2",
          "style": "light",
          "blocks": [],
          "defaultContent": [
            ".tickets-section"
          ]
        },
        {
          "id": "section-4",
          "name": "NASCAR Tickets",
          "selector": "#pg-2-3",
          "style": "light",
          "blocks": [
            "cards-tickets"
          ],
          "defaultContent": []
        },
        {
          "id": "section-5",
          "name": "IMSA Banner",
          "selector": "#pg-2-4",
          "style": "dark",
          "blocks": [
            "hero-banner"
          ],
          "defaultContent": []
